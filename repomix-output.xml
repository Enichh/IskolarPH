                    android:hint="Search scholarships..."
                    android:textSize="@dimen/text_size_small"
                    android:paddingHorizontal="@dimen/margin_small"
                    android:inputType="text"
                    android:maxLines="1"/>

                <!-- Vertical Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#E0E0E0"
                    android:layout_marginHorizontal="@dimen/margin_extra_small"/>

                <!-- Location Filter -->
                <ImageView
                    android:id="@+id/btn_filter_location"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_width="@dimen/icon_size_medium"
                    android:src="@drawable/ic_filter_list"
                    app:tint="#1F2F46"
                    android:contentDescription="Filter by Location"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <!-- GPA Filter -->
                <ImageView
                    android:id="@+id/btn_filter_gpa"
                    android:layout_height="@dimen/icon_size_medium"
                    android:layout_width="@dimen/icon_size_medium"
                    android:src="@android:drawable/ic_menu_sort_by_size"
                    app:tint="#1F2F46"
                    android:layout_marginStart="@dimen/margin_small"
                    android:contentDescription="Filter by GPA"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Separator Underline -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#D4A017"
            android:layout_marginTop="@dimen/margin_large"
            android:layout_marginBottom="@dimen/margin_small"
            android:layout_marginHorizontal="@dimen/padding_medium"/>

        <!-- Location Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingHorizontal="@dimen/padding_medium"
            android:paddingBottom="@dimen/margin_small">

            <TextView
                android:id="@+id/tvLocationHeader"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="All Scholarships"
                android:textSize="@dimen/text_size_medium"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <ImageButton
                android:id="@+id/btnRefreshLocation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:paddingTop="@dimen/margin_small"
                android:src="@android:drawable/ic_menu_rotate"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <!-- Filter Status -->
        <TextView
            android:id="@+id/tvFilterStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Location: All | GPA Filter: OFF"
            android:textSize="12sp"
            android:textColor="#D4A017"
            android:paddingHorizontal="@dimen/padding_medium"
            android:paddingBottom="@dimen/margin_small"
            android:gravity="center" />
    </LinearLayout>
    </ScrollView>

    <!-- Scholarship Cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_scholarships"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="@dimen/padding_medium"
        android:paddingTop="@dimen/margin_small"
        android:paddingBottom="106dp" />
</LinearLayout>
