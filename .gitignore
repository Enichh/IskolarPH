# Built application files
*.apk
*.ap_
*.aab

# Files for the ART/Dalvik VM
*.dex

# Java class files
*.class

# Generated files
bin/
gen/
out/

# Gradle files
.gradle/
build/

# Local configuration file (sdk paths, etc.)
local.properties

# Proguard folder generated by Eclipse
proguard/

# Log Files
*.log

# Android Studio Navigation editor temp files
.navigation/

# Android Studio captures folder
captures/

# IntelliJ IDEA / Android Studio
*.iml
.idea/
.idea/modules.xml
.idea/workspace.xml
.idea/tasks.xml
.idea/gradle.xml
.idea/dictionaries
.idea/libraries
.idea/assetWizardSettings.xml
.idea/caches/
.idea/jarRepositories.xml
.idea/compiler.xml
.idea/misc.xml
.idea/deploymentTargetDropDown.xml
.idea/render.experimental.xml

# Keystore files (debug keystores are usually regenerated, but keep private ones out)
*.jks
*.keystore

# Google Services (e.g., Firebase) – decide per project
google-services.json

# OS specific
.DS_Store
Thumbs.db

# Gradle wrapper (optional – you may want to keep it)
!gradle-wrapper.jar
