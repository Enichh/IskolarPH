<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#001F3F">

    <!-- HEADER -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="#001F3F"
        android:padding="16dp">



        <!-- Logo and Text -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/logo_iskolar_ph"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ISKOLAR PH"
                android:textColor="#FFFFFF"
                android:textSize="25sp"
                android:textStyle="bold" />
        </LinearLayout>
    </RelativeLayout>

    <!-- Header Underline -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#D4A017"/>

    <!-- Title, Search Bar, and Separator -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#001F3F">

        <!-- TITLE -->
        <TextView
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Scholarship Catalog"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginHorizontal="4dp"
            android:paddingBottom="12dp"/>

        <!-- SEARCH BAR WITH FILTERS -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="4dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:strokeColor="#E0E0E0"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_search"
                    app:tint="#666666"/>

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="0dp"
                    android:layout_height="40dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:hint="Search scholarships..."
                    android:textSize="14sp"
                    android:paddingHorizontal="8dp"
                    android:inputType="text"
                    android:maxLines="1"/>

                <!-- Vertical Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="#E0E0E0"
                    android:layout_marginHorizontal="8dp"/>

                <!-- Location Filter -->
                <ImageView
                    android:id="@+id/btn_filter_location"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_filter_list"
                    app:tint="#1F2F46"
                    android:contentDescription="Filter by Location"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

                <!-- Date Filter -->
                <ImageView
                    android:id="@+id/btn_filter_date"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="#1F2F46"
                    android:layout_marginStart="8dp"
                    android:contentDescription="Filter by Date"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"/>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Separator Underline -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#D4A017"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="8dp"
            android:layout_marginHorizontal="12dp"/>
    </LinearLayout>

    <!-- Scholarship Cards -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_scholarships"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingHorizontal="12dp"
        android:paddingTop="8dp" />
</LinearLayout>
