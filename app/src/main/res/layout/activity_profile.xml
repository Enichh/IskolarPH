<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#001F3F"
    android:fitsSystemWindows="true"
    tools:context=".MainActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- HEADER -->
            <RelativeLayout
                android:id="@+id/headerLayout"
                android:layout_width="match_parent"
                android:layout_height="@dimen/header_height"
                android:background="#001F3F">

                <!-- Centered Logo and Text -->
                <LinearLayout
                    android:layout_width="217dp"
                    android:layout_height="40dp"
                    android:layout_centerInParent="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivLogo"
                        android:layout_width="47dp"
                        android:layout_height="47dp"
                        android:layout_marginEnd="@dimen/margin_small"
                        android:src="@drawable/logo_iskolar_ph" />

                    <TextView
                        android:id="@+id/tvHeaderName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ISKOLAR PH"
                        android:textColor="#FFFFFF"
                        android:textSize="@dimen/text_size_title"
                        android:textStyle="bold" />
                </LinearLayout>


            </RelativeLayout>

            <!-- Header Underline -->
            <View
                android:id="@+id/headerUnderline"
                android:layout_width="match_parent"
                android:layout_height="@dimen/margin_extra_small"
                android:layout_marginTop="@dimen/margin_small"
                android:background="#D4A017" />

            <!-- Single Combined Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/margin_large"
                app:cardBackgroundColor="#F5F5F5"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/elevation_medium">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Profile Display Header -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="@dimen/padding_large">

                        <View
                            android:id="@+id/bannerBackground"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/margin_extra_small"
                            android:background="#154284"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Profile Image with Change Button -->
                        <FrameLayout
                            android:id="@+id/profileImageContainer"
                            android:layout_width="@dimen/icon_size_large"
                            android:layout_height="@dimen/icon_size_large"
                            android:layout_marginStart="@dimen/padding_large"
                            android:layout_marginTop="@dimen/padding_large"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <!-- Circular Profile Image Container -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:cardCornerRadius="80dp"
                                app:cardElevation="0dp"
                                app:cardPreventCornerOverlap="true"
                                app:cardUseCompatPadding="false">

                                <ImageView
                                    android:id="@+id/ivProfilePicture"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:background="#FFD700"
                                    android:padding="2dp"
                                    android:scaleType="centerCrop"
                                    android:src="@android:drawable/ic_menu_gallery" />
                            </androidx.cardview.widget.CardView>

                            <!-- Camera Icon Button -->
                            <androidx.cardview.widget.CardView
                                android:layout_width="36dp"
                                android:layout_height="36dp"
                                android:layout_gravity="bottom|end"
                                android:layout_marginEnd="4dp"
                                android:layout_marginBottom="4dp"
                                app:cardCornerRadius="18dp"
                                app:cardElevation="4dp"
                                app:cardBackgroundColor="#FFFFFF">

                                <ImageView
                                    android:id="@+id/btnChangePhoto"
                                    android:layout_width="match_parent"
                                    android:layout_height="match_parent"
                                    android:padding="8dp"
                                    android:src="@android:drawable/ic_menu_camera"
                                    app:tint="#154284" />
                            </androidx.cardview.widget.CardView>
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_small"
                            android:text="Your Name"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_large"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/profileImageContainer"
                            app:layout_constraintTop_toBottomOf="@id/profileImageContainer" />

                        <TextView
                            android:id="@+id/tvRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_extra_small"
                            android:background="#E0E0E0"
                            android:paddingHorizontal="@dimen/margin_small"
                            android:paddingVertical="@dimen/margin_extra_small"
                            android:text="Student"
                            android:textColor="#757575"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvProfileName" />

                        <TextView
                            android:id="@+id/tvCourseDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_medium"
                            android:text="Course / Program"
                            android:textColor="#3282C4"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvRole" />

                        <TextView
                            android:id="@+id/tvGPADisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPA: 0.0"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvCourseDisplay" />

                        <TextView
                            android:id="@+id/tvCollegeDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="School / University"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvGPADisplay" />

                        <TextView
                            android:id="@+id/tvLocationDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvCollegeDisplay" />

                        <TextView
                            android:id="@+id/tvContactDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contact Number"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvLocationDisplay" />

                        <TextView
                            android:id="@+id/tvEmailDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Address"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvContactDisplay" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Information Input/Edit Section -->
                    <LinearLayout
                        android:id="@+id/editSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/padding_large">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="@dimen/margin_medium"
                            android:background="#BDBDBD" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Setup Your Profile"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_medium"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_medium"
                            android:text="Full Name"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etFullName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="Enter your full name"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:inputType="textPersonName"
                            android:padding="@dimen/margin_small"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_medium"
                            android:text="Current School / University"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etCollege"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="Enter your school name"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:padding="@dimen/margin_small"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_medium"
                            android:text="Course / Program"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etCourse"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="Enter your course"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:padding="@dimen/margin_small"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_medium"
                            android:text="GPA / GWA"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etGPA"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="0.0"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:inputType="numberDecimal"
                            android:padding="@dimen/margin_small"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_medium"
                            android:text="Contact Number"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etContactNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="+63 XXX XXX XXXX"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:inputType="phone"
                            android:padding="@dimen/margin_small"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_medium"
                            android:text="Email Address"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="email@example.com"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:inputType="textEmailAddress"
                            android:padding="@dimen/margin_small"
                            android:textSize="@dimen/text_size_small"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_medium"
                            android:text="Location"
                            android:textColor="#212121"
                            android:textSize="@dimen/text_size_extra_small"
                            android:textStyle="bold" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <EditText
                                android:id="@+id/etLocation"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="#E0E0E0"
                                android:hint="City, Country"
                                android:textColor="#212121"
                                android:textColorHint="#757575"
                                android:padding="@dimen/margin_small"
                                android:textSize="@dimen/text_size_small"
                                android:textStyle="bold" />
                            <ImageButton
                                android:id="@+id/btnUseCurrentLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="@dimen/margin_small"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:padding="@dimen/margin_small"
                                android:src="@android:drawable/ic_menu_mylocation"
                                app:tint="#154284" />
                            <ProgressBar
                                android:id="@+id/progressBarLocation"
                                android:layout_width="@dimen/icon_size_medium"
                                android:layout_height="@dimen/icon_size_medium"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="@dimen/margin_small"
                                android:visibility="gone" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnUpdate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:backgroundTint="#FFD700"
                            android:text="Edit Profile"
                            android:textColor="#154284"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/margin_large"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <Button
                                android:id="@+id/btnThemeToggle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="@dimen/margin_small"
                                android:backgroundTint="#154284"
                                android:text="Toggle Theme"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btnExit"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:backgroundTint="#D32F2F"
                                android:text="Logout"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bottom padding for keyboard -->
            <View
                android:layout_width="match_parent"
                android:layout_height="@dimen/padding_large" />
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>