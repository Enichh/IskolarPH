<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#001F3F"
    tools:context=".MainActivity">

    <!-- Header Section -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingTop="8dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/logoContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="horizontal"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/ivLogo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_marginEnd="8dp"
                android:scaleType="centerCrop"
                android:src="@drawable/logo_iskolar_ph" />

            <TextView
                android:id="@+id/tvHeaderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IskolarPH"
                android:textColor="@android:color/white"
                android:textSize="18sp"
                android:textStyle="bold" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnEditToggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_edit"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@android:color/white" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:paddingBottom="106dp"
        android:clipToPadding="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerLayout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Single Combined Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                app:cardBackgroundColor="#F5F5F5"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Profile Display Header -->
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingBottom="16dp">

                        <View
                            android:id="@+id/bannerBackground"
                            android:layout_width="match_parent"
                            android:layout_height="10dp"
                            android:background="#154284"
                            app:layout_constraintTop_toTopOf="parent" />

                        <!-- Profile Image with Change Button -->
                        <FrameLayout
                            android:id="@+id/profileImageContainer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="20dp"
                            android:layout_marginTop="20dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent">

                            <ImageView
                                android:id="@+id/ivProfilePicture"
                                android:layout_width="90dp"
                                android:layout_height="90dp"
                                android:background="#FFD700"
                                android:padding="4dp"
                                android:scaleType="centerCrop"
                                android:src="@android:drawable/ic_menu_gallery" />

                            <ImageView
                                android:id="@+id/btnChangePhoto"
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:layout_gravity="bottom|end"
                                android:background="@android:color/white"
                                android:elevation="4dp"
                                android:padding="6dp"
                                android:src="@android:drawable/ic_menu_camera" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvProfileName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:text="Your Name"
                            android:textColor="#212121"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/profileImageContainer"
                            app:layout_constraintTop_toBottomOf="@id/profileImageContainer" />

                        <TextView
                            android:id="@+id/tvRole"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:background="#E0E0E0"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="2dp"
                            android:text="Student"
                            android:textColor="#757575"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvProfileName" />

                        <TextView
                            android:id="@+id/tvCourseDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Course / Program"
                            android:textColor="#3282C4"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvRole" />

                        <TextView
                            android:id="@+id/tvGPADisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="GPA: 0.0"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvCourseDisplay" />

                        <TextView
                            android:id="@+id/tvCollegeDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="School / University"
                            android:textColor="#212121"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvGPADisplay" />

                        <TextView
                            android:id="@+id/tvLocationDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Location"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvCollegeDisplay" />

                        <TextView
                            android:id="@+id/tvContactDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Contact Number"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvLocationDisplay" />

                        <TextView
                            android:id="@+id/tvEmailDisplay"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Email Address"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            app:layout_constraintStart_toStartOf="@id/tvProfileName"
                            app:layout_constraintTop_toBottomOf="@id/tvContactDisplay" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                    <!-- Information Input/Edit Section -->
                    <LinearLayout
                        android:id="@+id/editSection"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:layout_marginBottom="16dp"
                            android:background="#BDBDBD" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Setup Your Profile"
                            android:textColor="#212121"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Full Name"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etFullName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="Enter your full name"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:inputType="textPersonName"
                            android:padding="8dp"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Current School / University"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etCollege"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="Enter your school name"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:padding="8dp"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Course / Program"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etCourse"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="Enter your course"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:padding="8dp"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="GPA / GWA"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etGPA"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="0.0"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:inputType="numberDecimal"
                            android:padding="8dp"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Contact Number"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etContactNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="+63 XXX XXX XXXX"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:inputType="phone"
                            android:padding="8dp"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Email Address"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <EditText
                            android:id="@+id/etEmail"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:background="#E0E0E0"
                            android:hint="email@example.com"
                            android:textColor="#212121"
                            android:textColorHint="#757575"
                            android:inputType="textEmailAddress"
                            android:padding="8dp"
                            android:textSize="14sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="12dp"
                            android:text="Location"
                            android:textColor="#212121"
                            android:textSize="12sp"
                            android:textStyle="bold" />
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">
                            <EditText
                                android:id="@+id/etLocation"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:background="#E0E0E0"
                                android:hint="City, Country"
                                android:textColor="#212121"
                                android:textColorHint="#757575"
                                android:padding="8dp"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <ImageButton
                                android:id="@+id/btnUseCurrentLocation"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="8dp"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:padding="8dp"
                                android:src="@android:drawable/ic_menu_mylocation"
                                app:tint="#154284" />
                            <ProgressBar
                                android:id="@+id/progressBarLocation"
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="8dp"
                                android:visibility="gone" />
                        </LinearLayout>

                        <Button
                            android:id="@+id/btnUpdate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:backgroundTint="#FFD700"
                            android:text="Save Profile"
                            android:textColor="#154284"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="16dp"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <Button
                                android:id="@+id/btnThemeToggle"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:layout_marginEnd="8dp"
                                android:backgroundTint="#154284"
                                android:text="Toggle Theme"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />

                            <Button
                                android:id="@+id/btnExit"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:backgroundTint="#D32F2F"
                                android:text="Logout"
                                android:textColor="@android:color/white"
                                android:textStyle="bold" />
                        </LinearLayout>

                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>