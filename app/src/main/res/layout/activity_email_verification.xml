<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="?attr/colorSurface"
    android:fitsSystemWindows="true">

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progressBar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <!-- Email Icon -->
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_email"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:contentDescription="Email verification icon" />

    <!-- Title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verify Your Email"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="?attr/colorOnSurface"
        android:layout_marginBottom="8dp" />

    <!-- Email Display -->
    <TextView
        android:id="@+id/tvEmail"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="user@example.com"
        android:textSize="16sp"
        android:textColor="?attr/colorPrimary"
        android:layout_marginBottom="16dp" />

    <!-- Verification Status -->
    <TextView
        android:id="@+id/tvStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Status: Not Verified"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@android:color/holo_red_dark"
        android:layout_marginBottom="16dp" />

    <!-- Instruction Message -->
    <TextView
        android:id="@+id/tvMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Please verify your email to continue. Check your inbox for the verification link."
        android:textSize="14sp"
        android:textAlignment="center"
        android:layout_marginBottom="24dp"
        android:lineSpacingMultiplier="1.2" />

    <!-- Timer Display -->
    <TextView
        android:id="@+id/tvTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="12sp"
        android:textColor="?attr/colorOnSurfaceVariant"
        android:visibility="gone"
        android:layout_marginBottom="16dp" />

    <!-- Check Status Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnCheckStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Check Verification Status"
        android:layout_marginBottom="8dp"
        app:cornerRadius="8dp"
        style="@style/Widget.Material3.Button.OutlinedButton" />

    <!-- Resend Email Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnResend"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Resend Verification Email"
        android:layout_marginBottom="8dp"
        app:cornerRadius="8dp"
        style="@style/Widget.Material3.Button.OutlinedButton" />

    <!-- Continue Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnContinue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Continue to App"
        android:enabled="false"
        android:alpha="0.5"
        android:layout_marginBottom="16dp"
        app:cornerRadius="8dp" />

    <!-- Logout Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnLogout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Logout"
        android:textColor="?attr/colorError"
        app:cornerRadius="8dp"
        style="@style/Widget.Material3.Button.TextButton" />

</LinearLayout>